t_details[vars.item].activity.rawData | from_json).eventId }}\",\n  \"awsRegion\": \"{{ (vars.alert_details[vars.item].activity.rawData | from_json).awsRegion }}\",\n  \"eventName\": \"{{ (vars.alert_details[vars.item].activity.rawData | from_json).eventName }}\",\n  \"eventTime\": \"{{ (vars.alert_details[vars.item].activity.rawData | from_json).eventTime }}\",\n  \"requestID\": \"{{ (vars.alert_details[vars.item].activity.rawData | from_json).requestID }}\",\n  \"eventSource\": \"{{ (vars.alert_details[vars.item].activity.rawData | from_json).eventSource }}\",\n  \"userIdentityArn\": \"{{ (vars.alert_details[vars.item].activity.rawData | from_json).userIdentity.arn }}\",\n  \"userIdentityType\": \"{{ (vars.alert_details[vars.item].activity.rawData | from_json).userIdentity.type }}\",\n  \"userIdentityAccountId\": \"{{ (vars.alert_details[vars.item].activity.rawData | from_json).userIdentity.accountId }}\",\n  \"userIdentityPrincipalId\": \"{{ (vars.alert_details[vars.item].activity.rawData | from_json).userIdentity.principalId }}\",\n  \"sourceIPAddress\": \"{{ (vars.alert_details[vars.item].activity.rawData | from_json).sourceIPAddress }}\",\n  \"recipientAccountId\": \"{{ (vars.alert_details[vars.item].activity.rawData | from_json).recipientAccountId }}\",\n  \"bucketName\": \"{{ (vars.alert_details[vars.item].activity.rawData | from_json).requestParameters.bucketName }}\",\n  \"key\": \"{{ (vars.alert_details[vars.item].activity.rawData | from_json).requestParameters.key }}\"\n}"
